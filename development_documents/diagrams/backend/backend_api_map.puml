@startuml backend_api_map
skinparam style strictuml
title "Backend API Map"

left to right direction

package "FastAPI Backend" {
  rectangle "General\n--\nGET /\nGET /health" as general
  rectangle "Devices\n--\nGET /devices\nGET /devices/{id}\nPOST /devices\nDELETE /devices/{id}" as devices
  rectangle "Device Signals\n--\nPOST /devices/{id}/heartbeat\nPOST /devices/{id}/measurements" as signals

  general -[hidden]-> devices
  devices -[hidden]-> signals
}

@enduml
