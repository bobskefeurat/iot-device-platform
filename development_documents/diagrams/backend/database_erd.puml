@startuml database_erd
title "Database ERD"

entity "devices" as devices {
  * id : String
  --
  name : String
  last_seen : DateTime
}

entity "components" as components {
  * device_id : String
  * local_id : String
  --
  model_name : String
  component_type : String
}

entity "measurements" as measurements {
  * device_id : String
  * component_local_id : String
  * created_at : DateTime
  --
  mean_adc : Integer
  moisture_percent : Integer
}

devices ||--o{ components : device_id
components ||--o{ measurements : (device_id, local_id)

note right of components
PK = (device_id, local_id)
FK device_id -> devices.id
end note

note right of measurements
PK = (device_id, component_local_id, created_at)
Composite FK:
(device_id, component_local_id) ->
components(device_id, local_id)
end note

@enduml
