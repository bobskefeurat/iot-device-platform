@startuml device_registration_sequence

skinparam style strictuml
title "Device Registration Sequence"

participant "ESP32 Device" as esp32
participant "Backend API" as backend
participant "SQLite Database" as db

esp32 -> backend : POST /devices {id, name, components[]}
backend -> db : Find device by id

db --> backend : Device found / not found

alt Device found
backend -> backend : Use existing device
else Device not found
backend -> db : Create device
db --> backend : Device created
end

backend -> backend : Update device metadata
backend -> backend : Sync components
backend -> db : Commit changes
db --> backend : Changes saved

backend --> esp32 : HTTP response

@enduml
