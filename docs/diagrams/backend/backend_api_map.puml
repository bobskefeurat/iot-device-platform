@startuml backend_api_map
skinparam style strictuml
title "Backend API Map"

left to right direction

package "FastAPI Backend" {
  rectangle "main.py\n--\ncreate app\ninclude routers" as main
  rectangle "api/health.py\n--\nGET /\nGET /health" as general
  rectangle "api/devices.py\n--\nGET /devices\nGET /devices/{id}\nPOST /devices\nDELETE /devices/{id}" as devices
  rectangle "api/signals.py\n--\nPOST /devices/{id}/heartbeat\nPOST /devices/{id}/measurements" as signals
  rectangle "api/config.py\n--\nPOST /devices/{id}/config/update\nPOST /devices/{id}/config/sync" as config
  rectangle "services/devices.py\n--\nshared device logic" as device_services
  rectangle "services/config.py\n--\nconfig write + response helpers" as config_services

  main --> general
  main --> devices
  main --> signals
  main --> config
  devices --> device_services
  signals --> device_services
  config --> config_services
  general -[hidden]-> devices
  devices -[hidden]-> signals
  signals -[hidden]-> config
}

@enduml
