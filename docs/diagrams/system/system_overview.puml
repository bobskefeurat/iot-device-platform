@startuml system_overview
skinparam style strictuml
skinparam packageStyle rectangle
skinparam ArrowFontSize 12
left to right direction

title "IoT Device Platform - Current System Overview"

package "ESP32 Device" {
  rectangle "app_main" as app_main
  rectangle "Wi-Fi Manager" as wifi
  rectangle "Device Info" as device_info
  rectangle "Backend Client" as backend_client
  rectangle "Serial Menu" as serial_menu
  rectangle "Measurement Task" as measurement_task
  rectangle "Heartbeat Task" as heartbeat_task
  rectangle "Moisture Sensor\n+ Calibration / NVS" as sensor_runtime
}

package "FastAPI Backend" {
  rectangle "main.py\n--\nFastAPI app\ninclude_router(...)" as backend_main
  rectangle "api/health.py\n--\nGET /\nGET /health" as general_api
  rectangle "api/devices.py\n--\nGET /devices\nGET /devices/{id}\nPOST /devices\nDELETE /devices/{id}" as device_api
  rectangle "api/signals.py\n--\nPOST /devices/{id}/heartbeat\nPOST /devices/{id}/measurements" as signal_api
  rectangle "api/config.py\n--\nPOST /devices/{id}/config/update\nPOST /devices/{id}/config/sync" as config_api
  rectangle "services/devices.py\n--\nstatus + timestamps\ncomponent sync\nresponse building" as device_services
  rectangle "services/config.py\n--\nconfig write + response helpers" as config_services
  rectangle "models.py\nschemas.py\ndatabase.py" as backend_core
}

database "SQLite Database\n--\ndevices\ncomponents\nmeasurements\ndevice_config\nsensor_config" as db

app_main --> wifi : initialize / connect
app_main --> device_info : build id + name
app_main --> backend_client : register device
app_main --> serial_menu : start task
app_main --> measurement_task : start task
app_main --> heartbeat_task : start if registered

serial_menu --> sensor_runtime : live reading / calibration
measurement_task --> sensor_runtime : sample moisture
measurement_task --> backend_client : send measurement
heartbeat_task --> backend_client : send heartbeat\nreceive desired_config_id (unused)

backend_client --> device_api : registration
backend_client --> signal_api : heartbeat / measurements

backend_main --> general_api : include router
backend_main --> device_api : include router
backend_main --> signal_api : include router
backend_main --> config_api : include router

general_api -[hidden]-> device_api
device_api -[hidden]-> signal_api
signal_api -[hidden]-> config_api

device_api --> device_services : use helper logic
signal_api --> device_services : use utc_now()
config_api --> config_services : write config / build response

device_api --> backend_core : query / update
signal_api --> backend_core : query / update
config_api --> backend_core : query / update
backend_core --> db : persist / load

@enduml
